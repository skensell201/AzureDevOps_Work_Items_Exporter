{
  "name": "workitems-export",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json --output-path out",
    "package:quickexport": "npm run build && tfx extension create --manifest-globs vss-extension.quickexport.json --output-path out"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.230.0",
    "azure-devops-extension-sdk": "^4.0.2",
    "azure-devops-ui": "^2.167.75",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/react": "^12.1.5",
    "@types/jest": "^29.5.12",
    "@types/react": "^16.14.60",
    "@types/react-dom": "^16.9.24",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.0",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.17.0",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
