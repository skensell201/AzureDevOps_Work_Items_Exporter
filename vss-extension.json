{
  "manifestVersion": 1,
  "id": "workitems-export",
  "publisher": "iksoftware",
  "version": "1.5.1",
  "name": "Work Items Export",
  "description": "Download a team backlog level or a saved query to CSV/Excel with configurable columns, including rollup sums and hierarchy.",
  "content": { "details": { "path": "overview.md" } },
  "categories": ["Boards"],
  "targets": [{ "id": "Microsoft.TeamFoundation.Server", "version": "[17.0,)" }],
  "icons": { "default": "images/icon.png" },
  "scopes": ["vso.work", "vso.project", "vso.identity"],
  "contributions": [
    {
      "id": "work-items-export-hub",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-work-web.work-hub-group"],
      "properties": { "name": "Work Items Export", "uri": "dist/hub.html" }
    }
  ],
  "files": [
    { "path": "dist", "addressable": true },
    { "path": "images", "addressable": true }
  ]
}
